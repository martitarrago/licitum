# Supabase
# Usa la "Direct connection" (puerto 5432) para migraciones y desarrollo local.
# Para producción con alta concurrencia usa el "Connection Pooling" (puerto 6543)
# y añade ?prepared_statement_cache_size=0&statement_cache_size=0 al final.
# Importante: cambiar el esquema de `postgresql://` a `postgresql+asyncpg://`.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

APP_ENV=dev
DEBUG=true

# Cloudflare R2 — S3-compatible object storage
# Obtenerlos en: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=licitum-certificados
# Si has conectado un dominio público o un bucket .r2.dev, define la base pública.
# Ejemplo: https://pub-xxxxx.r2.dev   o   https://cdn.tudominio.com
R2_PUBLIC_URL_BASE=

# Celery + Redis
# En dev: arranca redis local (`docker run -p 6379:6379 redis:7`) o usa Upstash/Railway.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
